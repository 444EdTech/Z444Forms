rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net: default deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Check if ID matches requirements
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    // Validate registration body schema
    function isValidRegistration(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'phone', 'btechYear', 'department', 'createdAt'])
        && data.keys().size() == 7
        && data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() > 3 && data.email.size() <= 100 && data.email.matches('^[^@]+@[^@]+\\.[^@]+$')
        && data.phone is string && data.phone.size() >= 8 && data.phone.size() <= 15
        && data.btechYear is string && (data.btechYear == '1' || data.btechYear == '2' || data.btechYear == '3' || data.btechYear == '4' || data.btechYear == 'Completed')
        && data.department is string && data.department.size() > 0 && data.department.size() <= 50
        && data.createdAt is timestamp;
    }

    // Validate global reminder flags
    function isValidReminder(data) {
      return (data.june6_8pm_sent == null || data.june6_8pm_sent is bool)
        && (data.june7_10am_sent == null || data.june7_10am_sent is bool);
    }

    // Validate feedback body schema
    function isValidFeedback(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'rating', 'comments', 'createdAt'])
        && data.keys().size() == 6
        && data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() > 3 && data.email.size() <= 100 && data.email.matches('^[^@]+@[^@]+\\.[^@]+$')
        && data.rating is int && data.rating >= 1 && data.rating <= 5
        && data.comments is string && data.comments.size() > 0 && data.comments.size() <= 2000
        && data.createdAt is timestamp;
    }

    // Validate community registration schema
    function isValidCommunityRegistration(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'phone', 'paymentScreenshot', 'amountPaid', 'promoApplied', 'status', 'createdAt'])
        && data.keys().size() == 9
        && data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() > 3 && data.email.size() <= 100 && data.email.matches('^[^@]+@[^@]+\\.[^@]+$')
        && data.phone is string && data.phone.size() >= 8 && data.phone.size() <= 20
        && data.paymentScreenshot is string && data.paymentScreenshot.size() > 0 && data.paymentScreenshot.size() <= 16777216 // Limit to 16MB for safety
        && data.amountPaid is int && (data.amountPaid == 999 || data.amountPaid == 244)
        && data.promoApplied is string && data.promoApplied.size() <= 50
        && data.status is string && (data.status == 'pending' || data.status == 'approved' || data.status == 'rejected')
        && data.createdAt is timestamp;
    }
    
    match /registrations/{registrationId} {
      // Anyone can create a registration, provided it is valid and well-formed
      allow create: if isValidId(registrationId) && isValidRegistration(request.resource.data);
      
      // Disallow all client-side updates and deletes to preserve data integrity and protect entries
      allow update, delete: if false;
      
      // Reading registrations is strictly isolated to the verified masterclass host email
      allow list, get: if request.auth != null && request.auth.token.email == '444edtech@gmail.com' && request.auth.token.email_verified == true;
    }

    match /feedbacks/{feedbackId} {
      // Anyone can submit post-event feedback if it passes strict format schemas
      allow create: if isValidId(feedbackId) && isValidFeedback(request.resource.data);
      
      // Disallow client updates and deletes
      allow update, delete: if false;
      
      // Reading feedback list is isolated to the verified admin
      allow list, get: if request.auth != null && request.auth.token.email == '444edtech@gmail.com' && request.auth.token.email_verified == true;
    }

    match /reminders/{reminderId} {
      // Anyone can read and update the global reminder flags if formatted correctly (enables headless container syncing)
      allow read, write: if isValidId(reminderId) && (request.resource == null || isValidReminder(request.resource.data));
    }

    match /community_registrations/{registrationId} {
      // Anyone can submit a community registration application with valid payload
      allow create: if isValidId(registrationId) && isValidCommunityRegistration(request.resource.data);
      
      // Updates (approving/rejecting) and reads (admin viewing list) are only allowed by verified admin
      allow list, get, update: if request.auth != null && request.auth.token.email == '444edtech@gmail.com' && request.auth.token.email_verified == true;
      allow delete: if false;
    }
  }
}
